# Backlog API Configuration
BACKLOG_HOST=your-space.backlog.jp
BACKLOG_API_KEY=your_api_key_here

# Script Configuration
BACKLOG_PROJECT_ID_OR_KEY=YOUR_PROJECT_KEY

# Optional: Parent document ID to create documents under a specific parent
# If not set, documents will be created at the root level
# BACKLOG_PARENT_DOCUMENT_ID=123456
